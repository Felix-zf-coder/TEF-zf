{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug STLink",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "stlink",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/Robot.elf",
            "device": "STM32F427IIH6",
            "interface": "swd",
            "runToEntryPoint": "main",
            "armToolchainPath": "D:/STM32CubeCLT/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin",
            "serverpath": "D:/STM32CubeCLT/STM32CubeCLT_1.21.0/STLink-gdb-server/bin/ST-LINK_gdbserver.exe",
            "stm32cubeprogrammer": "D:/STM32CubeCLT/STM32CubeCLT_1.21.0/STM32CubeProgrammer/bin",
            "liveWatch": {
                "enabled": true,
                "samplingInterval": 100
            }
        }
    ]
}
